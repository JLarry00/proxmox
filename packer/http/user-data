#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: es
  ssh:
    install-server: true
    allow-pw: true
  storage:
    layout:
      name: direct
  identity:
    hostname: ubuntu-template
    username: admin_user
    # La contraseña en autoinstall debe estar hasheada. 
    # Sustituye este valor por el hash de tu contraseña generado mediante 'openssl passwd -6 <contraseña>' en una terminal.
    # Nuestro caso: openssl passwd -6 "Password123!"
    password: "$6$XzhYcZaTi2Qazqyc$hXTUmEzo3akmHWUUwL7aYq/BxEzyB7TgYZqXaSm1RUS9bZsW8ZXOyGwG8BeIyrwP/CO7u5yF3ri1.zk89tgQe1"
  packages:
    - qemu-guest-agent